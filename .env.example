APP_PORT=8080
MAX_VIEWERS=12

# Keep these values identical in the app and LiveKit configuration.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecretdevsecretdevsecretdevsecret

# "auto" uses ws(s)://CURRENT_BROWSER_HOST:7880.
LIVEKIT_URL=auto

# Use 127.0.0.1 for same-computer testing. For classroom LAN testing,
# set this to the Docker host's LAN address, for example 192.168.1.50.
LIVEKIT_NODE_IP=127.0.0.1
